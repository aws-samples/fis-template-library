{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowFISExperimentLogging",
            "Effect": "Allow",
            "Action": [
                "logs:CreateLogDelivery",
                "logs:PutResourcePolicy",
                "logs:DescribeResourcePolicies",
                "logs:DescribeLogGroups"
            ],
            "Resource": "*"
        },
        {
            "Sid": "AllowSSMDocumentExecution",
            "Effect": "Allow",
            "Action": [
                "ssm:StartAutomationExecution",
                "ssm:GetAutomationExecution",
                "ssm:StopAutomationExecution"
            ],
            "Resource": [
                "arn:aws:ssm:*:*:document/ElastiCache-Primary-Node-Reboot",
                "arn:aws:ssm:*:*:automation-definition/ElastiCache-Primary-Node-Reboot:*",
                "arn:aws:ssm:*:*:automation-execution/*"
            ]
        },
        {
            "Sid": "AllowPassRole",
            "Effect": "Allow",
            "Action": [
                "iam:PassRole"
            ],
            "Resource": [
                "arn:aws:iam::*:role/*"
            ],
            "Condition": {
                "StringEquals": {
                    "iam:PassedToService": "ssm.amazonaws.com"
                }
            }
        }
    ]
}
