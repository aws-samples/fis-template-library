{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowElastiCacheReboot",
            "Effect": "Allow",
            "Action": [
                "elasticache:RebootCacheCluster"
            ],
            "Resource": "*"
        },
        {
            "Sid": "AllowElastiCacheDescribe",
            "Effect": "Allow",
            "Action": [
                "elasticache:DescribeCacheClusters"
            ],
            "Resource": "*"
        }
    ]
}
