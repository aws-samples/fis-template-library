{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowSSMAutomationExecution",
      "Effect": "Allow",
      "Action": [
        "ssm:StartAutomationExecution",
        "ssm:GetAutomationExecution",
        "ssm:StopAutomationExecution"
      ],
      "Resource": [
        "arn:aws:ssm:<YOUR REGION>:<YOUR AWS ACCOUNT>:automation-definition/ChaosExperiment:*",
        "arn:aws:ssm:<YOUR REGION>:<YOUR AWS ACCOUNT>:automation-execution/*",
        "arn:aws:ssm:<YOUR REGION>:<YOUR AWS ACCOUNT>:document/ChaosExperiment"
      ]
    },
    {
      "Sid": "AllowPassRoleToSSM",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::*:role/ChaosExperiment-SSM-Automation-Role",
      "Condition": { "StringEquals": { "iam:PassedToService": "ssm.amazonaws.com" } }
    },
    {
      "Sid": "AllowCloudWatchAlarmsForStopConditions",
      "Effect": "Allow",
      "Action": [ "cloudwatch:DescribeAlarms" ],
      "Resource": "*"
    },
    {
      "Sid": "AllowCloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogDelivery",
        "logs:PutResourcePolicy",
        "logs:DescribeResourcePolicies",
        "logs:DescribeLogGroups"
      ],
      "Resource": "*"
    }
  ]
}
