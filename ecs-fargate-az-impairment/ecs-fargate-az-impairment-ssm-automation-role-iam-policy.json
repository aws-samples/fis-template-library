{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ECSPermissions",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeServices",
        "ecs:UpdateService",
        "ecs:DescribeClusters"
      ],
      "Resource": [
        "arn:aws:ecs:<YOUR REGION>:<YOUR AWS ACCOUNT>:cluster/*",
        "arn:aws:ecs:<YOUR REGION>:<YOUR AWS ACCOUNT>:service/*/*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/FIS-Ready": "True"
        }
      }
    },
    {
      "Sid": "EC2DescribePermissions",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeSubnets",
        "ec2:DescribeNetworkInterfaces"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CloudWatchLogsPermissions",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "*"
    }
  ]
}
