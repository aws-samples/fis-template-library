{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowFISExperimentLogging",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogDelivery",
        "logs:PutResourcePolicy",
        "logs:DescribeResourcePolicies",
        "logs:DescribeLogGroups"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowECSTargetResolution",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeTasks",
        "ecs:ListTasks"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowECSStopTask",
      "Effect": "Allow",
      "Action": [
        "ecs:StopTask"
      ],
      "Resource": [
        "arn:aws:ecs:<YOUR REGION>:<YOUR AWS ACCOUNT>:task/<YOUR ECS CLUSTER>/*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/FIS-Ready": "True"
        }
      }
    },
    {
      "Sid": "AllowECSNetworkFaultInjection",
      "Effect": "Allow",
      "Action": [
        "ecs:RunTask"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "ecs:cluster": "arn:aws:ecs:<YOUR REGION>:<YOUR AWS ACCOUNT>:cluster/<YOUR ECS CLUSTER>"
        }
      }
    },
    {
      "Sid": "AllowSSMDocumentExecution",
      "Effect": "Allow",
      "Action": [
        "ssm:StartAutomationExecution",
        "ssm:GetAutomationExecution",
        "ssm:StopAutomationExecution"
      ],
      "Resource": [
        "arn:aws:ssm:<YOUR REGION>:<YOUR AWS ACCOUNT>:document/ecs-fargate-az-impairment-subnet-automation",
        "arn:aws:ssm:<YOUR REGION>:<YOUR AWS ACCOUNT>:automation-definition/ecs-fargate-az-impairment-subnet-automation:*",
        "arn:aws:ssm:<YOUR REGION>:<YOUR AWS ACCOUNT>:automation-execution/*"
      ]
    },
    {
      "Sid": "AllowPassRole",
      "Effect": "Allow",
      "Action": ["iam:PassRole"],
      "Resource": ["arn:aws:iam::<YOUR AWS ACCOUNT>:role/<YOUR SSM AUTOMATION ROLE>"]
    }
  ]
}
