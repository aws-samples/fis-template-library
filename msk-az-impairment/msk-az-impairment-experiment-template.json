{
    "description": "Amazon MSK AZ Impairment - Disrupts cross-AZ connectivity to MSK broker subnets in a target Availability Zone to test cluster resilience to an AZ failure",
    "roleArn": "arn:aws:iam::<YOUR AWS ACCOUNT>:role/<YOUR ROLE NAME>",
    "actions": {
        "disrupt-broker-az-connectivity": {
            "actionId": "aws:network:disrupt-connectivity",
            "description": "Deny cross-AZ traffic to and from the MSK broker subnet in the target Availability Zone",
            "parameters": {
                "duration": "PT5M",
                "scope": "availability-zone"
            },
            "targets": {
                "Subnets": "msk-broker-subnet-in-target-az"
            }
        }
    },
    "stopConditions": [
        {
            "source": "none"
        }
    ],
    "targets": {
        "msk-broker-subnet-in-target-az": {
            "resourceType": "aws:ec2:subnet",
            "resourceArns": [
                "arn:aws:ec2:<YOUR REGION>:<YOUR AWS ACCOUNT>:subnet/<YOUR MSK BROKER SUBNET ID>"
            ],
            "selectionMode": "ALL"
        }
    },
    "tags": {
        "Name": "msk-az-impairment",
        "Purpose": "chaos-engineering"
    },
    "experimentOptions": {
        "accountTargeting": "single-account",
        "emptyTargetResolutionMode": "fail"
    }
}
