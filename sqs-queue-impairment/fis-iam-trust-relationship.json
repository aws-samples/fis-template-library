{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Principal": {
                "Service": "fis.amazonaws.com"
            },
            "Action": "sts:AssumeRole",
            "Condition": {
                "StringEquals": {
                    "aws:SourceAccount": "<YOUR AWS ACCOUNT>"
                },
                "ArnLike": {
                    "aws:SourceArn": "arn:aws:fis:<YOUR REGION>:<YOUR AWS ACCOUNT>:experiment/*"
                }
            }
        }
    ]
}
