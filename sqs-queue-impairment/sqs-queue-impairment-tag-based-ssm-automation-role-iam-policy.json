{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowQueueDiscovery",
      "Effect": "Allow",
      "Action": [
        "sqs:ListQueues",
        "sqs:ListQueueTags"
      ],
      "Resource": "arn:aws:sqs:<YOUR REGION>:<YOUR AWS ACCOUNT>:*"
    },
    {
      "Sid": "AllowPolicyChangeOnTaggedQueues",
      "Effect": "Allow",
      "Action": [
        "sqs:GetQueueAttributes",
        "sqs:SetQueueAttributes"
      ],
      "Resource": "arn:aws:sqs:<YOUR REGION>:<YOUR AWS ACCOUNT>:*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/FIS-Ready": "True"
        }
      }
    }
  ]
}
